# Reason Ready — node configuration (environment file).
# Copy to ~/.config/rro/config.env (rootless) or /etc/rro/config.env and edit.

# ---- identity & network ----------------------------------------------------
# This node's a2a identity on the mesh.
RRO_NODE=rro-1
# Persistent estate path (RocksDB directory; created if missing).
RRO_ESTATE=/var/lib/rro/estate
# a2a layer-2 listener (warp point address). Unset to disable the network.
RRO_LISTEN=0.0.0.0:7878
# Ops HTTP surface: prometheus /metrics + /healthz /livez /readyz. Unset to disable.
RRO_OPS_ADDR=0.0.0.0:9090
# DuckDB-ready JSONL event stream. Unset to disable.
RRO_EVENTS=/var/lib/rro/events.jsonl
# Log filter.
RUST_LOG=info
# Capability token: when set, every a2a message except ping must bear it.
# RRO_TOKEN=change-me
# Strict mode: apply resource quotas (payload/top_k/batch caps).
# RRO_STRICT=1

# ---- model backends (see docs/MODELS.md) -----------------------------------
# Fetch the base weights first (one command, ~1.2 GB each, verified byte-exact):
#   ./scripts/fetch-models.sh          # embedder + reranker
# then set RRO_*_WEIGHTS below to where they landed (default: <repo>/models/...).
#
# Which embedder to load. One of:
#   deterministic         — the zero-weight default (dev/CI only; NOT semantic)
#   candle-qwen           — real Qwen3 embedding backbone via candle (needs weights)
#   llamacpp | vllm       — an OpenAI-compatible embedding server over HTTP
#   onnx                  — an ONNX embedding model via ort (needs weights)
#   remote                — call another RRO node's model over a2a
# RRO_EMBEDDER=candle-qwen
# Path to the embedder weights dir (model.safetensors + tokenizer.json + config.json).
# RRO_EMBEDDER_WEIGHTS=/var/lib/rro/models/qwen3-embedding-0.6b
# Force output dimensionality (else read from the model config; Qwen3 is MRL 32..1024).
# RRO_EMBED_DIM=1024

# Which reranker to load. One of:
#   lexical               — BM25, zero-weight (the default)
#   candle-cross-encoder  — real Qwen3-Reranker via candle (needs weights)
#   llamacpp | vllm       — an HTTP reranking server
#   onnx | remote
# RRO_RERANKER=candle-cross-encoder
# RRO_RERANKER_WEIGHTS=/var/lib/rro/models/qwen3-reranker-0.6b

# Inference device: cpu | cuda:0 | metal. Default cpu.
# RRO_DEVICE=cuda:0
# Embedding batch size (throughput vs latency).
# RRO_EMBED_BATCH=32
